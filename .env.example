# Forum Environment Variables
# Copy this file to .env and fill in your values.

# TLS
# AUTOCERT_HOST=example.com,www.example.com   # domain for Let's Encrypt (comma-separated)
# AUTOCERT_CACHE_DIR=/certs                    # certificate cache directory
# DEV_MODE=true                                 # enable self-signed HTTPS for local dev

# Server
# PORT=443                                      # HTTPS port (default: 443 with autocert, 8443 dev, 8081 HTTP)
# DB_PATH=forum.db                              # SQLite database path

# Session
# SESSION_SECURE=true                           # set Secure flag on cookies (required for HTTPS)

# CSRF
# CSRF_SECRET=base64-32-byte-key               # CSRF token secret (optional)

# Database Encryption
# DB_ENCRYPTION_KEY=base64-32-byte-key          # generate: openssl rand -base64 32

# Rate Limiting (requests per minute)
# RATE_LIMIT_LOGIN=5
# RATE_LIMIT_REGISTER=3
# RATE_LIMIT_POST=30
# RATE_LIMIT_API=60

# OAuth
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Admin
ADMIN_EMAIL=admin@example.com
